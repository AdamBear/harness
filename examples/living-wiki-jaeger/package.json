{
  "name": "@purista/living-wiki-jaeger-example",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "npm run predev:api",
    "predev:api": "npm run build --workspace @purista/harness && npm run build --workspace @purista/harness-openai",
    "dev": "concurrently -k -n api,web -c blue,green \"npm:dev:api:run\" \"npm:dev:web\"",
    "dev:api": "npm run dev:api:run",
    "dev:api:run": "tsx watch src/server.ts",
    "dev:web": "vite --host 127.0.0.1",
    "build": "tsc -p tsconfig.json && vite build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run src --exclude 'src/**/*.ui.test.tsx'",
    "test:ui": "vitest run src/**/*.ui.test.tsx --environment jsdom",
    "jaeger": "docker run --rm --name jaeger -p 16686:16686 -p 4317:4317 -p 4318:4318 -p 5778:5778 -p 9411:9411 cr.jaegertracing.io/jaegertracing/jaeger:2.17.0",
    "lint": "echo 'no lint configured for @purista/living-wiki-jaeger-example'"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.216.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-node": "^0.216.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@purista/harness": "*",
    "@purista/harness-openai": "*",
    "@types/three": "^0.184.0",
    "@vitejs/plugin-react": "^6.0.1",
    "ai-elements": "^1.9.0",
    "beautiful-mermaid": "^1.1.3",
    "hono": "^4.12.17",
    "json-renderer": "npm:@patrikstep/json-renderer@^3.1.1",
    "lucide-react": "^1.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "three": "^0.184.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "jsdom": "^29.1.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}

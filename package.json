{
	"name": "@purista/agent-harness-repo",
	"version": "0.0.0",
	"private": true,
	"description": "Self-hosted enterprise agent harness.",
	"type": "module",
	"engines": {
		"node": ">=24.15.0"
	},
	"workspaces": [
		"packages/*",
		"examples/*"
	],
	"scripts": {
		"lint": "npm run lint --workspaces --if-present",
		"typecheck": "npm run typecheck --workspaces --if-present",
		"test": "npm run test --workspaces --if-present",
		"test:contracts": "npm run test:contracts --workspace @purista/harness",
		"test:failure": "npm run test:failure --workspace @purista/harness",
		"test:integration": "npm run test:integration --workspace @purista/harness && npm run test --workspace @purista/quickstart",
		"test:types": "npm run test:types --workspace @purista/harness",
		"build": "npm run build --workspaces --if-present"
	}
}
